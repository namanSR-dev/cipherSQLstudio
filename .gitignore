# ------------------------------
# Node.js dependencies
# ------------------------------
node_modules/
**/node_modules/

# ------------------------------
# Build outputs and caches
# ------------------------------
dist/
build/
out/
.next/
**/.next/
.turbo/
**/.turbo/
coverage/
**/coverage/
.nyc_output/
.cache/
.parcel-cache/
*.tsbuildinfo
.eslintcache

# ------------------------------
# Logs and runtime artifacts
# ------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.pid
*.pid.lock
*.seed

# ------------------------------
# Environment files and secrets (recursive)
# ------------------------------
.env
.env.*
**/.env
**/.env.*
*.env
*.env.*
*.local
*.secret
secrets.*
**/secrets/
*.pem
*.key
*.crt
*.p12
*.pfx

# Keep safe templates tracked
!.env.example
!.env.*.example
!.env.sample
!.env.*.sample

# ------------------------------
# Package manager caches
# ------------------------------
.npm/
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# ------------------------------
# IDE and OS noise
# ------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
Desktop.ini

