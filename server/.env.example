# Express server port
PORT=5000

# PostgreSQL connection string (used by pg Pool)
POSTGRES_URL=postgresql://postgres:password@localhost:5432/cipher_sql

# MongoDB connection string (required at startup)
MONGO_URI=mongodb://127.0.0.1:27017/cipher_sql

# Google Gemini API key for AI hint generation
GEMINI_API_KEY=your_gemini_api_key_here
